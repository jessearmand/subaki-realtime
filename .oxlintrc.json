{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "react-perf", "typescript", "unicorn", "oxc"],
  "env": {
    "browser": true,
    "es2024": true
  },
  "rules": {
    "no-unused-vars": "warn",
    "no-console": "off"
  },
  "ignorePatterns": [".next", "node_modules", "next-env.d.ts", "components/ui", "scripts", "public"]
}
